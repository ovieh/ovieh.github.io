---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true && data.archived !== true;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const title = "Ovieh Mosley | Brewing Up Code";
const description = "Portfolio and writing of Ovieh Mosley, a Senior Product Engineer building scalable SaaS platforms, real-time systems, and high-impact user experiences.";
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />
  
  <div class="page-wrapper">
    <section class="hero-section">
      <div class="hero-grid">
        <div class="hero-main">
          <p class="hero-eyebrow font-mono text-accent animate-reveal" style="animation-delay: 0.1s;">// Senior Product Engineer</p>
          <h1 class="hero-title animate-reveal" style="animation-delay: 0.2s;">
            Building <br/>
            <span class="italic-serif text-accent">product systems</span><br/>
            that scale.
          </h1>
          <p class="hero-subtitle animate-reveal" style="animation-delay: 0.3s;">
            I build full-stack SaaS products, real-time collaboration systems, and backend architecture that turns product ideas into dependable user-facing software.
          </p>
        </div>
        
        <div class="hero-stats animate-reveal" style="animation-delay: 0.4s;">
          <div class="stat-box">
            <span class="stat-value font-mono">8+</span>
            <span class="stat-label">Years building product software</span>
          </div>
          <div class="stat-box">
            <span class="stat-value font-mono">1M+</span>
            <span class="stat-label">Users reached across shipped platforms</span>
          </div>
          <div class="stat-box">
            <span class="stat-value font-mono">0→1</span>
            <span class="stat-label">Product ownership from concept to scale</span>
          </div>
        </div>
      </div>
    </section>

    <section class="writing-section animate-reveal" style="animation-delay: 0.5s;">
      <div class="section-header">
        <h2 class="section-title">Current Writing</h2>
        <div class="technical-divider"></div>
      </div>

      <div class="post-list">
        {sortedPosts.length > 0 ? (
          sortedPosts.map((post) => (
            <PostCard post={post} />
          ))
        ) : (
          <div class="empty-state">
            <p class="font-mono">NO_DATA_FOUND</p>
            <p>New writing is on the way. Earlier bootcamp reflections are available in the archive.</p>
          </div>
        )}
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-wrapper {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .hero-section {
    padding: 8rem 0 6rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 4rem;
    position: relative;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: -50vw;
    right: -50vw;
    height: 100%;
    background: radial-gradient(circle at 70% 30%, var(--accent-soft), transparent 50%);
    z-index: -1;
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: end;
  }

  .hero-eyebrow {
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  .hero-title {
    font-size: clamp(4rem, 8vw, 7rem);
    line-height: 0.9;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
  }

  .italic-serif {
    font-style: italic;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    max-width: 45ch;
    opacity: 0.8;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--border-color);
    border-left: 1px solid var(--border-color);
  }

  .stat-box {
    padding: 2rem;
    border-bottom: 1px solid var(--border-color);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: rgba(10, 10, 10, 0.5);
    backdrop-filter: blur(10px);
    transition: var(--transition);
  }

  .stat-box:hover {
    background: var(--accent-soft);
  }

  .stat-value {
    font-size: 3rem;
    font-weight: 300;
    color: var(--heading-color);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  .section-header {
    margin-bottom: 3rem;
    display: flex;
    align-items: baseline;
    gap: 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin: 0;
  }

  .technical-divider {
    flex-grow: 1;
    height: 1px;
    background: var(--border-color);
    position: relative;
  }

  .technical-divider::after {
    content: '';
    position: absolute;
    right: 0;
    top: -3px;
    width: 7px;
    height: 7px;
    background: var(--accent-color);
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    padding: 4rem;
    border: 1px dashed var(--border-color);
    text-align: center;
    color: var(--text-color);
    opacity: 0.7;
  }
  
  .empty-state p.font-mono {
    color: var(--accent-color);
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .hero-stats {
      grid-template-columns: repeat(3, 1fr);
      border-left: none;
      border-top: none;
    }
    
    .stat-box {
      padding: 1.5rem 1rem;
      border-left: 1px solid var(--border-color);
      border-top: 1px solid var(--border-color);
    }
    
    .section-header {
      flex-direction: column;
      gap: 1rem;
    }
  }

  @media (max-width: 600px) {
    .hero-section {
      padding: 4rem 0 3rem;
    }
    .hero-stats {
      grid-template-columns: 1fr;
      border-left: 1px solid var(--border-color);
    }
  }
</style>
