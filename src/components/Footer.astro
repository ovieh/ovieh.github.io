---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-info">
      <p class="footer-eyebrow">Ovieh Mosley</p>
      <p class="footer-summary">Senior Product Engineer building scalable SaaS platforms, real-time systems, and product-focused full-stack software.</p>
      <!-- <p class="footer-meta">Based in DFW, Texas.</p> -->
      <p class="footer-copyright">&copy; {currentYear} Ovieh Mosley. All rights reserved.</p>
    </div>
    
    <div class="footer-links">
      <a href="https://github.com/ovieh" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
      <a href="mailto:ovieh.mosley@gmail.com" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"></path><path d="m22 6-10 7L2 6"></path></svg>
      </a>
      <a href="https://linkedin.com/in/ovieh" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
      <a href="/rss.xml" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    padding: 3rem 0;
    border-top: 1px solid var(--border-color);
    background-color: var(--card-bg);
  }

  .footer-content {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .footer-info p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-color);
  }

  .footer-eyebrow {
    color: var(--accent-color) !important;
    font-size: 0.8rem !important;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.75rem !important;
  }

  .footer-summary {
    max-width: 36rem;
    font-size: 1rem !important;
    line-height: 1.7;
    color: var(--heading-color) !important;
  }

  .footer-meta,
  .footer-copyright {
    opacity: 0.72;
    margin-top: 0.35rem !important;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-color);
    opacity: 0.7;
    transition: var(--transition);
  }

  .footer-links a:hover {
    color: var(--accent-color);
    opacity: 1;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
