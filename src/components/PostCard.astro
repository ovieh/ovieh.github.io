---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, tags, description } = post.data;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<article class="post-row">
  <a href={`/post/${post.id}/`} class="post-link">
    <div class="row-content">
      <div class="meta-column font-mono">
        <time datetime={date.toISOString()} class="post-date">{formattedDate}</time>
        <div class="post-tags">
          {tags && tags.slice(0, 2).map(tag => (
            <span class="tag">[{tag}]</span>
          ))}
        </div>
      </div>
      
      <div class="title-column">
        <h2 class="post-title font-serif">{title}</h2>
        <p class="post-description">
          {description || (post.body ? post.body.substring(0, 160).replace(/[#*]/g, '') + '...' : '')}
        </p>
      </div>
      
      <div class="action-column font-mono">
        <span class="read-more">
          READ_DOC
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  .post-row {
    border-bottom: 1px solid var(--border-color);
    transition: var(--transition);
  }

  .post-row:first-child {
    border-top: 1px solid var(--border-color);
  }

  .post-link {
    display: block;
    color: inherit;
    text-decoration: none;
    padding: 2.5rem 0;
  }

  .row-content {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: 2rem;
    align-items: start;
  }

  .meta-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-color);
    opacity: 0.7;
    font-size: 0.85rem;
  }

  .post-tags {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tag {
    color: var(--accent-color);
  }

  .title-column {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-title {
    margin: 0;
    font-size: 2.5rem;
    color: var(--heading-color);
    transition: var(--transition);
  }

  .post-row:hover .post-title {
    color: var(--accent-color);
    transform: translateX(10px);
  }

  .post-description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-color);
    opacity: 0.8;
    max-width: 60ch;
  }

  .action-column {
    opacity: 0;
    transform: translateX(-10px);
    transition: var(--transition);
  }

  .post-row:hover .action-column {
    opacity: 1;
    transform: translateX(0);
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent-color);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .row-content {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .meta-column {
      flex-direction: row;
      justify-content: space-between;
      width: 100%;
    }
    
    .post-tags {
      flex-direction: row;
    }
    
    .post-title {
      font-size: 2rem;
    }

    .action-column {
      opacity: 1;
      transform: none;
      margin-top: 1rem;
    }
    
    .post-row:hover .post-title {
      transform: none;
    }
  }
</style>
